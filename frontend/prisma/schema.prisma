generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}



model User {
  id             String   @id @default(uuid())
  email          String?  @unique
  name           String
  goal           String   @default("Maintenance")
  height         Float?
  weight         Float?
  age            Int?
  gender         String?  // "male" | "female"
  activityLevel  String   @default("moderate")
  tdee           Int?
  targetCalories Int?
  targetProtein  Int?
  targetCarbs    Int?
  targetFat      Int?
  isPro          Boolean  @default(false)
  proExpiresAt   DateTime?
  onboardingDone Boolean  @default(false)
  dietType       String?
  foodPrefs      String?  @db.Text

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  habits        Habit[]
  foodLogs      FoodLog[]
  activityLogs  ActivityLog[]
  dailyScores   DailyScore[]
  waterLogs     WaterLog[]
  journalEntries JournalEntry[]
  weightLogs     WeightLog[]
}

model Habit {
  id            String     @id @default(uuid())
  userId        String
  name          String
  frequency     String     @default("daily")
  currentStreak Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs      HabitLog[]

  @@index([userId])
}

model HabitLog {
  id            String   @id @default(uuid())
  habitId       String
  completedDate DateTime @default(now())
  createdAt     DateTime @default(now())

  habit         Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@index([habitId, completedDate])
}

model FoodLog {
  id               String   @id @default(uuid())
  userId           String
  description      String
  calories         Int
  protein          Float
  carbs            Float
  fat              Float
  fiber            Float    @default(0)
  sodium           Float    @default(0)
  addedSugar       Float    @default(0)
  naturalSugar     Float    @default(0)
  loggedAt         DateTime @default(now())

  generationSource String   @default("manual")
  confidenceScore  Float?
  modelId          String?
  promptHash       String?
  reviewStatus     String?

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

model ActivityLog {
  id             String   @id @default(uuid())
  userId         String
  name           String
  duration       Int?
  caloriesBurned Int
  loggedAt       DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

model DailyScore {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @db.Date
  score     Int
  insight   String
  bodyPct   Int      @default(33)
  mindPct   Int      @default(33)
  energyPct Int      @default(34)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model WaterLog {
  id        String   @id @default(uuid())
  userId    String
  amountMl  Int
  loggedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

model JournalEntry {
  id        String   @id @default(uuid())
  userId    String
  content   String   @db.Text
  mood      String?
  audioUrl  String?
  entryDate DateTime @db.Date
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, entryDate])
}

model WeightLog {
  id        String   @id @default(uuid())
  userId    String
  weight    Float
  loggedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

