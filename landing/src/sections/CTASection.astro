---
---
<section id="cta" class="relative z-10 py-36 px-6 text-center overflow-hidden">
  <!-- Rich background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="bg-orb w-[1000px] h-[1000px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" style="background: radial-gradient(circle, rgba(0,243,255,0.06) 0%, transparent 50%);"></div>
    <div class="bg-orb w-[600px] h-[600px] top-0 right-0" style="background: radial-gradient(circle, rgba(139,92,246,0.04) 0%, transparent 70%);"></div>
  </div>

  <!-- Horizontal lines decoration -->
  <div class="absolute inset-x-0 top-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(0,243,255,0.1), transparent);" aria-hidden="true"></div>

  <div class="relative max-w-4xl mx-auto">
    <h2 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-heading italic leading-[0.95] mb-8 fade-up">
      <span class="block text-white/80">Stop searching.</span>
      <span class="block text-gradient-mixed mt-2" style="filter: drop-shadow(0 0 30px rgba(0,243,255,0.2));">Start logging.</span>
    </h2>

    <p class="text-white/30 text-xl md:text-2xl mb-12 fade-up font-light">
      Synapze is free forever. The last health app you'll ever need.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-5 mb-8 fade-up">
      <a href="/auth" class="btn-cyan text-lg px-10">
        Launch Web App
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="#community" class="btn-ghost">Join the Community</a>
    </div>

    <p class="text-white/15 text-sm fade-up tracking-wide">No credit card · No ads · No data selling · Just health.</p>
  </div>
</section>
