---
const features = [
  {
    num: '01',
    title: 'Neural Score Engine',
    desc: 'A single number that grades your day. Understand your body like a Formula 1 car.',
    icon: '<path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/>',
  },
  {
    num: '02',
    title: 'AI Vision Logging',
    desc: 'Snap a meal. Our AI identifies every ingredient and portion. Free, unlimited, private.',
    icon: '<path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/>',
  },
  {
    num: '03',
    title: 'Sugar Intelligence',
    desc: 'For the first time, see exactly how much natural vs added sugar you\'re consuming.',
    icon: '<line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/>',
  },
  {
    num: '04',
    title: 'Smart Nudges & Journaling',
    desc: 'Voice-powered journal that connects mood to food. The AI notices patterns and gives actionable feedback.',
    icon: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>',
  },
]
---

<section id="features" class="relative z-10 py-32 px-6">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] rounded-full bg-cyan-500/5 blur-[140px]"></div>
  </div>

  <div class="relative max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <div class="badge mb-6 fade-up">The Human OS Dashboard</div>
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-heading italic mb-4 fade-up">
        Everything your body<br/>
        <span class="text-gradient-cyan">actually needs.</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      {features.map((f) => (
        <div class="feature-card fade-up">
          <div class="shimmer-line"></div>

          <!-- Number -->
          <span class="absolute top-4 right-6 text-6xl font-black text-white/[0.03]">{f.num}</span>

          <!-- Icon -->
          <div class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center mb-5">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00f3ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
          </div>

          <h3 class="text-xl font-bold text-white mb-2 font-body">{f.title}</h3>
          <p class="text-white/40 text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
