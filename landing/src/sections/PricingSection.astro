---
const features = [
  'AI Vision Food Logging',
  'Neural Score Engine',
  'Habit & Streak Tracking',
  'Activity & Workout Logging',
  'Sugar Intelligence™',
  'Personalised AI Coaching',
  'Smart Analytics Dashboard',
  'Unlimited History',
]
---

<section id="pricing" class="relative z-10 py-32 px-6">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="bg-orb w-[800px] h-[800px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" style="background: radial-gradient(circle, rgba(0,243,255,0.04) 0%, transparent 50%);"></div>
  </div>

  <div class="relative max-w-3xl mx-auto text-center">
    <div class="badge mb-6 fade-up">Pricing</div>
    <h2 class="text-4xl sm:text-5xl md:text-6xl font-heading italic mb-4 fade-up">
      Free forever.<br/>
      <span class="text-gradient-cyan">Seriously.</span>
    </h2>
    <p class="text-white/30 text-lg mb-14 fade-up">No catch. No premium tier. Just health.</p>

    <!-- Pricing card -->
    <div class="pricing-card liquid-glass-strong fade-up">
      <!-- Shimmer -->
      <div class="absolute inset-0 animate-shimmer pointer-events-none rounded-[1.5rem]" aria-hidden="true"></div>

      <div class="relative z-10">
        <!-- Price -->
        <div class="mb-2">
          <span class="text-7xl font-black text-white">$0</span>
          <span class="text-lg text-white/25 font-medium ml-2">/ month</span>
        </div>
        <p class="text-white/30 text-sm mb-10">No credit card. No trial period. Full access, forever.</p>

        <!-- Features grid -->
        <div class="grid sm:grid-cols-2 gap-3 mb-10 text-left">
          {features.map((f) => (
            <div class="flex items-center gap-3 py-2">
              <div class="w-5 h-5 rounded-full bg-cyan-500/15 flex items-center justify-center shrink-0">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#00f3ff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span class="text-white/50 text-sm">{f}</span>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <a href="/auth" class="btn-cyan w-full justify-center text-lg">
          Create Free Account
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
