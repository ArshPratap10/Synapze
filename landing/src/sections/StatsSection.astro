    <div class="stat-card fade-up">
      <p class="text-4xl md:text-5xl font-black text-gradient-cyan mb-2">98%</p>
      <p class="text-sm text-white/30 font-medium">AI Accuracy</p>
    </div>
    <div class="stat-card fade-up">
      <p class="text-4xl md:text-5xl font-black text-gradient-cyan mb-2">4.9★</p>
      <p class="text-sm text-white/30 font-medium">User Rating</p>
    </div>
